{
  "name": "effector-lexical",
  "version": "0.0.0",
  "description": "Effector bindings for the Lexical text editor",
  "type": "module",
  "license": "MIT",
  "author": "Olovyannikov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Olovyannikov/effector-lexical.git"
  },
  "homepage": "https://olovyannikov.github.io/effector-lexical/",
  "bugs": "https://github.com/Olovyannikov/effector-lexical/issues",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "effector",
    "lexical",
    "editor",
    "bindings",
    "react"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.5.1",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./html": {
      "import": {
        "types": "./dist/html/index.d.ts",
        "default": "./dist/html/index.js"
      },
      "require": {
        "types": "./dist/html/index.d.cts",
        "default": "./dist/html/index.cjs"
      }
    },
    "./markdown": {
      "import": {
        "types": "./dist/markdown/index.d.ts",
        "default": "./dist/markdown/index.js"
      },
      "require": {
        "types": "./dist/markdown/index.d.cts",
        "default": "./dist/markdown/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && node scripts/build-types.mjs && node scripts/copy-cts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check:exports": "publint --strict && attw --pack . --profile node16",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "lefthook install"
  },
  "peerDependencies": {
    "@lexical/clipboard": ">=0.40.0",
    "@lexical/html": ">=0.40.0",
    "@lexical/markdown": ">=0.40.0",
    "@lexical/react": ">=0.40.0",
    "effector": ">=23.0.0",
    "lexical": ">=0.40.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@lexical/clipboard": {
      "optional": true
    },
    "@lexical/html": {
      "optional": true
    },
    "@lexical/markdown": {
      "optional": true
    },
    "@lexical/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@lexical/clipboard": "^0.45.0",
    "@lexical/code": "^0.45.0",
    "@lexical/eslint-plugin": "^0.45.0",
    "@lexical/html": "^0.45.0",
    "@lexical/link": "^0.45.0",
    "@lexical/list": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-effector": "^0.18.0",
    "jsdom": "^25.0.1",
    "lefthook": "^1.10.1",
    "lexical": "^0.45.0",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
